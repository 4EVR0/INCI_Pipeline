# =====================================

# CosIng Ingredient Collector Config

# =====================================

# Base URL for CosIng API

COSING_BASE_URL=https://ec.europa.eu/growth/tools-databases/cosing/api

# =====================================

# Crawling Configuration

# =====================================

# Number of results per page (CosIng API max = 100)

PAGE_SIZE=100

# Delay between API requests (seconds)

# Increase if you encounter rate limiting

SLEEP_SEC=1

# =====================================

# Query Splitting Configuration

# =====================================

# Maximum recursion depth when splitting queries

# Used to avoid the 10,000 result API limitation

MAX_QUERY_DEPTH=6

# Seed characters used to generate initial query prefixes

# Example: "abcdefghijklmnopqrstuvwxyz"

SEED_CHARS=abcdefghijklmnopqrstuvwxyz

# Characters used when expanding query prefixes

# Example: "abcdefghijklmnopqrstuvwxyz0123456789"

NEXT_CHARS=abcdefghijklmnopqrstuvwxyz0123456789

# =====================================

# Output Paths

# =====================================

# Directory where collected data will be stored

DATA_DIR=./data

# Directory where logs will be stored

LOG_DIR=./logs
